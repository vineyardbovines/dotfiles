{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ccusage",
  "title": "Claude Code Usage (ccusage)",
  "description": "Monitor Claude Code usage with real-time tracking",
  "categories": [
    "Developer Tools"
  ],
  "icon": "extension-icon.png",
  "author": "nyatinte",
  "contributors": [
    "bohdan_zhuravel",
    "zzyfisher",
    "garrick_zhang",
    "pernielsentikaer",
    "raulg"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "ccusage",
      "title": "Claude Code Usage",
      "subtitle": "ccusage",
      "description": "Monitor Claude Code usage with real-time tracking",
      "mode": "view"
    },
    {
      "name": "menubar-ccusage",
      "title": "Claude Code Usage in Menu Bar",
      "subtitle": "ccusage",
      "description": "Show Claude Code usage in menu bar",
      "mode": "menu-bar",
      "preferences": [
        {
          "name": "menuBarTitle",
          "type": "dropdown",
          "required": false,
          "title": "Menu Bar Status",
          "description": "What to display as text next to the icon in the menu bar",
          "default": "todayUsage",
          "data": [
            {
              "title": "Today's Usage (Cost + Tokens)",
              "value": "todayUsage"
            },
            {
              "title": "Today's Cost",
              "value": "todayCost"
            },
            {
              "title": "Monthly Cost",
              "value": "monthlyCost"
            },
            {
              "title": "Today's Tokens",
              "value": "todayTokens"
            },
            {
              "title": "5-Hour Limit",
              "value": "fiveHour"
            },
            {
              "title": "7-Day Limit",
              "value": "sevenDay"
            },
            {
              "title": "Highest Utilization",
              "value": "utilization"
            },
            {
              "title": "None",
              "value": "none"
            }
          ]
        },
        {
          "name": "showRemainingUsage",
          "type": "dropdown",
          "required": false,
          "title": "Progress Bar Mode",
          "description": "Whether progress bars show remaining capacity or consumed usage",
          "default": "remaining",
          "data": [
            {
              "title": "Remaining",
              "value": "remaining"
            },
            {
              "title": "Consumed",
              "value": "consumed"
            }
          ]
        },
        {
          "name": "progressBarStyle",
          "type": "dropdown",
          "required": false,
          "title": "Progress Bar Style",
          "description": "Visual style for rate limit progress bars",
          "default": "solid",
          "data": [
            {
              "title": "Solid (█░)",
              "value": "solid"
            },
            {
              "title": "Blocks (▰▱)",
              "value": "blocks"
            },
            {
              "title": "ASCII (#-)",
              "value": "ascii"
            }
          ]
        }
      ]
    },
    {
      "name": "claude-code-stats",
      "title": "Claude Code Stats",
      "subtitle": "ccusage",
      "description": "Update command subtitle with Claude Code usage data",
      "mode": "no-view",
      "interval": "5m",
      "preferences": [
        {
          "name": "subtitleTemplate",
          "type": "textfield",
          "required": false,
          "title": "Subtitle Template",
          "description": "Template for the subtitle. Available placeholders: {dailyCost}, {dailyTokens}, {dailyInputTokens}, {dailyOutputTokens}, {dailyRatio}, {monthlyCost}, {monthlyTokens}, {monthlyRatio}, {usageLimit}",
          "default": "Today: {dailyCost}",
          "placeholder": "e.g. Today: {dailyCost} · Month: {monthlyCost}"
        }
      ]
    }
  ],
  "preferences": [
    {
      "name": "defaultView",
      "type": "dropdown",
      "required": false,
      "title": "Default View",
      "description": "Choose the default section to display when opening the extension",
      "default": "today",
      "data": [
        {
          "title": "Today Usage",
          "value": "today"
        },
        {
          "title": "Session Usage",
          "value": "session"
        },
        {
          "title": "Cost Analysis",
          "value": "cost"
        },
        {
          "title": "Model Breakdown",
          "value": "model"
        },
        {
          "title": "Usage Limits",
          "value": "usage-limits"
        }
      ]
    },
    {
      "name": "usageLimitsRefreshInterval",
      "type": "dropdown",
      "required": false,
      "title": "Usage Limits Refresh Interval",
      "description": "How often to refresh usage limits data",
      "default": "60",
      "data": [
        {
          "title": "30 seconds",
          "value": "30"
        },
        {
          "title": "1 minute (Recommended)",
          "value": "60"
        },
        {
          "title": "2 minutes",
          "value": "120"
        },
        {
          "title": "5 minutes",
          "value": "300"
        },
        {
          "title": "10 minutes",
          "value": "600"
        }
      ]
    },
    {
      "name": "customNpxPath",
      "type": "textfield",
      "required": false,
      "title": "Custom npx Path",
      "description": "Override the default npx path if needed (optional)",
      "placeholder": "e.g., /usr/local/bin/npx or ~/.local/bin/npx"
    },
    {
      "name": "useDirectCcusageCommand",
      "type": "checkbox",
      "required": false,
      "label": "Use Direct 'ccusage' Command",
      "description": "Use 'ccusage' command directly instead of 'npx ccusage@latest' (useful when npx has network issues)",
      "default": false
    }
  ],
  "tools": [
    {
      "name": "get-daily-usage",
      "title": "Get Daily Usage",
      "description": "Get today's Claude Code usage including cost, tokens, and statistics",
      "instructions": "Get today's Claude Code usage including cost, tokens, and statistics\n\n@param input, ,- Optional input parameters for filtering and formatting\n@returns Daily usage data with cost and token information\n@throws Error when ccusage CLI is not available or returns invalid data",
      "input": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string",
            "description": "Start date in YYYYMMDD format"
          },
          "until": {
            "type": "string",
            "description": "End date in YYYYMMDD format"
          },
          "order": {
            "type": "string",
            "description": "Sort order",
            "enum": [
              "desc",
              "asc"
            ]
          },
          "breakdown": {
            "type": "boolean",
            "description": "Show per-model cost breakdown"
          }
        },
        "required": []
      },
      "confirmation": false
    },
    {
      "name": "get-total-usage",
      "title": "Get Total Usage",
      "description": "Get comprehensive Claude Code usage statistics including totals, sessions, and model breakdowns",
      "instructions": "Get comprehensive Claude Code usage statistics including totals, sessions, and model breakdowns\n\n@returns Complete usage statistics with model-wise breakdown\n@throws Error when ccusage CLI is not available or returns invalid data",
      "confirmation": false
    },
    {
      "name": "get-monthly-usage",
      "title": "Get Monthly Usage",
      "description": "Get current month's Claude Code usage statistics and model breakdowns",
      "instructions": "Get current month's Claude Code usage statistics and model breakdowns\n\n@param input, ,- Optional input parameters for filtering and formatting\n@returns Monthly usage data with model-wise breakdown\n@throws Error when ccusage CLI is not available or returns invalid data",
      "input": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string",
            "description": "Start date in YYYYMMDD format"
          },
          "until": {
            "type": "string",
            "description": "End date in YYYYMMDD format"
          },
          "order": {
            "type": "string",
            "description": "Sort order",
            "enum": [
              "desc",
              "asc"
            ]
          },
          "breakdown": {
            "type": "boolean",
            "description": "Show per-model cost breakdown"
          },
          "offline": {
            "type": "boolean",
            "description": "Use offline mode"
          }
        },
        "required": []
      },
      "confirmation": false
    },
    {
      "name": "get-session-usage",
      "title": "Get Session Usage",
      "description": "Get detailed session-by-session Claude Code usage statistics",
      "instructions": "Get detailed session-by-session Claude Code usage statistics\n\n@param input, ,- Optional input parameters for filtering and formatting\n@returns Session usage data with individual session details\n@throws Error when ccusage CLI is not available or returns invalid data",
      "input": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string",
            "description": "Start date in YYYYMMDD format"
          },
          "until": {
            "type": "string",
            "description": "End date in YYYYMMDD format"
          },
          "order": {
            "type": "string",
            "description": "Sort order",
            "enum": [
              "desc",
              "asc"
            ]
          },
          "breakdown": {
            "type": "boolean",
            "description": "Show per-model cost breakdown"
          }
        },
        "required": []
      },
      "confirmation": false
    },
    {
      "name": "get-usage-limits",
      "title": "Get Usage Limits",
      "description": "Get Claude API usage limits showing 5-hour and 7-day utilization percentages and reset times",
      "instructions": "Get Claude API usage limits including 5-hour and 7-day utilization percentages\n\n@param input, ,- Optional input parameters for formatting\n@returns Usage limit data with utilization percentages and reset times\n@throws Error when credentials are not found or API returns invalid data",
      "input": {
        "type": "object",
        "properties": {
          "includeRawTimestamps": {
            "type": "boolean",
            "description": "Include raw reset timestamps in ISO format"
          }
        },
        "required": []
      },
      "confirmation": false
    }
  ],
  "ai": {
    "instructions": "Analyze Claude Code usage statistics and costs. All cost values are in USD ($). When displaying costs, include the $ symbol. You can convert USD amounts to other currencies when requested (JPY, EUR, etc.).",
    "evals": [
      {
        "input": "@ccusage What's my total cost?",
        "mocks": {
          "get-total-usage": {
            "totalCost": 2.45,
            "totalTokens": 23000,
            "inputTokens": 15000,
            "outputTokens": 8000,
            "cacheCreationTokens": 500,
            "cacheReadTokens": 1200,
            "sessions": 12,
            "modelBreakdowns": [
              {
                "modelName": "claude-3-5-sonnet-20241022",
                "inputTokens": 10000,
                "outputTokens": 6000,
                "totalTokens": 16000,
                "totalCost": 1.8
              }
            ]
          }
        },
        "expected": [
          {
            "callsTool": "get-total-usage"
          }
        ]
      },
      {
        "input": "@ccusage Show me today's usage",
        "mocks": {
          "get-daily-usage": {
            "cost": 0.65,
            "inputTokens": 2500,
            "outputTokens": 1800,
            "totalTokens": 4300,
            "date": "2024-01-15"
          }
        },
        "expected": [
          {
            "callsTool": "get-daily-usage"
          }
        ]
      },
      {
        "input": "@ccusage Show me this month's breakdown",
        "mocks": {
          "get-monthly-usage": {
            "month": "2024-01",
            "totalCost": 12.75,
            "totalTokens": 85000,
            "inputTokens": 50000,
            "outputTokens": 35000,
            "cacheCreationTokens": 2000,
            "cacheReadTokens": 5000,
            "modelBreakdowns": [
              {
                "modelName": "claude-3-5-sonnet-20241022",
                "inputTokens": 35000,
                "outputTokens": 25000,
                "totalTokens": 60000,
                "totalCost": 9
              }
            ]
          }
        },
        "expected": [
          {
            "callsTool": "get-monthly-usage"
          }
        ]
      },
      {
        "input": "@ccusage Show me my recent sessions",
        "mocks": {
          "get-session-usage": {
            "sessions": [
              {
                "sessionId": "session-123",
                "totalCost": 0.38,
                "totalTokens": 2700,
                "inputTokens": 1500,
                "outputTokens": 1200,
                "cacheCreationTokens": 50,
                "cacheReadTokens": 100,
                "modelName": "claude-3-5-sonnet-20241022",
                "date": "2024-01-15T10:30:00Z"
              }
            ],
            "sessionCount": 1
          }
        },
        "expected": [
          {
            "callsTool": "get-session-usage"
          }
        ]
      },
      {
        "input": "@ccusage Which model costs me the most?",
        "mocks": {
          "get-total-usage": {
            "totalCost": 2.45,
            "totalTokens": 23000,
            "inputTokens": 15000,
            "outputTokens": 8000,
            "cacheCreationTokens": 500,
            "cacheReadTokens": 1200,
            "sessions": 12,
            "modelBreakdowns": [
              {
                "modelName": "claude-3-5-sonnet-20241022",
                "inputTokens": 10000,
                "outputTokens": 6000,
                "totalTokens": 16000,
                "totalCost": 1.8
              },
              {
                "modelName": "claude-3-haiku-20240307",
                "inputTokens": 5000,
                "outputTokens": 2000,
                "totalTokens": 7000,
                "totalCost": 0.65
              }
            ]
          }
        },
        "expected": [
          {
            "callsTool": "get-total-usage"
          }
        ]
      },
      {
        "input": "@ccusage Convert my total cost to yen",
        "mocks": {
          "get-total-usage": {
            "totalCost": 2.45,
            "totalTokens": 23000,
            "inputTokens": 15000,
            "outputTokens": 8000,
            "cacheCreationTokens": 500,
            "cacheReadTokens": 1200,
            "sessions": 12,
            "modelBreakdowns": []
          }
        },
        "expected": [
          {
            "callsTool": "get-total-usage"
          }
        ]
      }
    ]
  },
  "dependencies": {
    "@raycast/api": "^1.99.4",
    "@raycast/utils": "^2.2.2",
    "ccusage": "^0.6.2",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.39.3",
    "semver": "^7.6.3",
    "ts-pattern": "^5.7.1",
    "zod": "^3.25.61"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@raycast/eslint-config": "^2.1.1",
    "@types/jest": "^30.0.0",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "@types/semver": "^7.5.8",
    "eslint": "^9.22.0",
    "jest": "^30.2.0",
    "knip": "^5.61.2",
    "prettier": "^3.5.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "knip": "knip",
    "lint": "ray lint",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish",
    "test": "jest"
  },
  "platforms": [
    "macOS"
  ]
}